# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# Gemini (Cloud LLM) — ขอ key ฟรีที่ https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ChromaDB (Long-term Memory)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# SQLite — ชี้ไปที่ NAS path (ถ้าไม่ใส่จะใช้ local ./chat_history.db)
# Mac mount:  DB_PATH=/Volumes/NAS/hybrid-ai/chat_history.db
# Synology:   DB_PATH=/volume1/docker/hybrid-ai/chat_history.db
DB_PATH=

# NAS data folder สำหรับ docker-compose volume mount (Synology path)
# NAS_DATA_PATH=/volume1/docker/hybrid-ai
NAS_DATA_PATH=

# Obsidian Vault — path ของ vault บน NAS (ภายใน Docker container)
# Synology: OBSIDIAN_VAULT_PATH=/vault
OBSIDIAN_VAULT_PATH=
